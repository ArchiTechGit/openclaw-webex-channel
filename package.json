{
  "name": "@richwats/webex",
  "version": "0.2.7",
  "description": "OpenClaw Cisco Webex channel plugin with inbound routing and automatic retry handling",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "keywords": [
    "openclaw",
    "webex",
    "cisco",
    "channel-plugin",
    "bot",
    "chat",
    "integration"
  ],
  "author": "Richard Watson",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richwats/openclaw-webex-channel.git"
  },
  "bugs": {
    "url": "https://github.com/richwats/openclaw-webex-channel/issues"
  },
  "homepage": "https://github.com/richwats/openclaw-webex-channel#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && npm run check",
    "prepack": "npm run build"
  },
  "dependencies": {
    "express": "^4.21.2",
    "webex-node-bot-framework": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/express": "^4.17.21",
    "typescript": "^5.8.3"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
